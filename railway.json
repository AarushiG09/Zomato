{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "python scripts/ingest_dataset.py"
  },
  "deploy": {
    "startCommand": "sh -c 'uvicorn StitchUIDesign.server:app --host 0.0.0.0 --port $PORT'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
